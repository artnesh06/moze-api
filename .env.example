PORT=3000
HOST=0.0.0.0

# Comma-separated browser origins allowed to call the API
CORS_ORIGIN=https://www.mozestreet.art,https://mozestreet.art,http://localhost:8765,http://127.0.0.1:8765

# Robinhood Chain
RPC_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663
MOZE_CA=0x0e579bcec21ae9dc5400db46cab67d5a8d0a58cc

# Soft stake rate (same as frontend)
MOZE_RATE_PER_DAY=10

# SQLite path (mount a volume at /data in Coolify)
DATABASE_PATH=./data/moze.db

# Holder scan cache TTL (ms) — default 10 min
HOLDERS_CACHE_TTL_MS=600000

# Max supply to scan for ownerOf
MAX_SUPPLY=1000

# Signature validity window (ms)
SIG_MAX_AGE_MS=600000
